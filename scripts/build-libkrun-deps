#!/usr/bin/env bash
set -euo pipefail

LIBKRUN_VERSION="${LIBKRUN_VERSION:-1.19.4}"
ROOT_DIR="$(git rev-parse --show-toplevel)"
TARGET_TRIPLE="${TARGET_TRIPLE:-$(rustc -vV | awk '/host:/ { print $2 }')}"
BUILD_ROOT="${KRUN_BUILD_DIR:-$ROOT_DIR/target/build/libkrun/$TARGET_TRIPLE}"
OUT_DIR="${KRUN_DEPS_DIR:-$ROOT_DIR/target/libs/krun/$TARGET_TRIPLE}"
RUNTIME_DIR="${KRUN_RUNTIME_DIR:-$ROOT_DIR/target/release}"

require_tool() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'missing required tool: %s\nRun this from `nix develop` so the flake-provided krun toolchain is active.\n' "$1" >&2
    exit 1
  fi
}

require_common_tools() {
  require_tool cargo
  require_tool git
  require_tool pkg-config
  require_tool rustc
}

clone_libkrun() {
  local dest="$BUILD_ROOT/libkrun-src"
  if [ ! -d "$dest/.git" ]; then
    git clone --depth 1 --branch "v$LIBKRUN_VERSION" --recurse-submodules \
      https://github.com/libkrun/libkrun.git "$dest"
  else
    git -C "$dest" fetch --depth 1 origin "refs/tags/v$LIBKRUN_VERSION:refs/tags/v$LIBKRUN_VERSION"
    git -C "$dest" checkout --detach "v$LIBKRUN_VERSION"
    git -C "$dest" submodule update --init --recursive --depth 1
  fi
}

apply_libkrun_patches() {
  local dest="$BUILD_ROOT/libkrun-src"
  local patch
  local patches=("$ROOT_DIR"/patches/libkrun/*.patch)

  if [ ! -e "${patches[0]}" ]; then
    return
  fi

  for patch in "${patches[@]}"; do
    if git -C "$dest" apply --reverse --check "$patch" >/dev/null 2>&1; then
      continue
    fi
    git -C "$dest" apply --check "$patch"
    git -C "$dest" apply "$patch"
  done
}

prepare_dirs() {
  mkdir -p "$BUILD_ROOT" "$OUT_DIR" "$RUNTIME_DIR"
  rm -f "$OUT_DIR"/libkrunfw*.so "$OUT_DIR"/libkrunfw*.so.* "$OUT_DIR"/libkrunfw*.dylib
}

build_libkrun() {
  clone_libkrun
  apply_libkrun_patches
  cargo build --manifest-path "$BUILD_ROOT/libkrun-src/Cargo.toml" \
    -p libkrun \
    --lib \
    --release \
    --target-dir "$BUILD_ROOT/libkrun-src/target" \
    --no-default-features \
    --features blk \
    --features net
}

build_linux() {
  require_tool patchelf

  build_libkrun

  cp -L "$BUILD_ROOT/libkrun-src/target/release/libkrun.so" "$OUT_DIR/libkrun.so"
  patchelf --set-soname libkrun.so "$OUT_DIR/libkrun.so"
  cp -L "$OUT_DIR/libkrun.so" "$RUNTIME_DIR/libkrun.so"
}

build_macos() {
  require_tool clang
  require_tool install_name_tool
  require_tool codesign

  if [ "$(uname -m)" != "arm64" ]; then
    printf 'macOS libkrun builds are only supported on arm64 hosts.\n' >&2
    exit 1
  fi

  build_libkrun

  local libkrun_dylib="$BUILD_ROOT/libkrun-src/target/release/libkrun.dylib"
  if [ ! -f "$libkrun_dylib" ]; then
    printf 'libkrun build did not produce %s\n' "$libkrun_dylib" >&2
    exit 1
  fi

  cp -L "$libkrun_dylib" "$OUT_DIR/libkrun.dylib"

  install_name_tool -id "@rpath/libkrun.dylib" "$OUT_DIR/libkrun.dylib"

  codesign -s - --force "$OUT_DIR/libkrun.dylib"
  cp -L "$OUT_DIR/libkrun.dylib" "$RUNTIME_DIR/libkrun.dylib"
}

require_common_tools
prepare_dirs

case "$(uname -s)" in
  Linux)
    build_linux
    ;;
  Darwin)
    build_macos
    ;;
  *)
    printf 'unsupported host OS: %s\n' "$(uname -s)" >&2
    exit 1
    ;;
esac

printf 'Built libkrun dependencies in %s\n' "$OUT_DIR"
printf 'Installed libkrun runtime in %s\n' "$RUNTIME_DIR"
printf 'Use: export KRUN_DEPS_DIR=%q\n' "$OUT_DIR"
