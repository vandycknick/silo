#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 2 ]; then
  printf 'usage: package-krun-runtime <profile: debug|release> <output-dir>\n' >&2
  exit 2
fi

PROFILE="$1"
OUT_DIR="$2"
ROOT_DIR="$(git rev-parse --show-toplevel)"
TARGET_TRIPLE="${TARGET_TRIPLE:-$(rustc -vV | awk '/host:/ { print $2 }')}"
KRUN_DEPS_DIR="${KRUN_DEPS_DIR:-$ROOT_DIR/target/libs/krun/$TARGET_TRIPLE}"
KRUN_BIN="$ROOT_DIR/target/$PROFILE/krun"

if [ ! -x "$KRUN_BIN" ]; then
  printf 'krun binary not found: %s\nBuild it first with `cargo build -p krun` or `cargo build -p krun --release`.\n' "$KRUN_BIN" >&2
  exit 1
fi

if [ ! -d "$KRUN_DEPS_DIR" ]; then
  printf 'krun dependency directory not found: %s\nRun `build-libkrun-deps` first or set KRUN_DEPS_DIR.\n' "$KRUN_DEPS_DIR" >&2
  exit 1
fi

mkdir -p "$OUT_DIR"
rm -f "$OUT_DIR"/libkrunfw*.so "$OUT_DIR"/libkrunfw*.so.* "$OUT_DIR"/libkrunfw*.dylib
cp -f "$KRUN_BIN" "$OUT_DIR/krun"

case "$(uname -s)" in
  Darwin)
    cp -f "$KRUN_DEPS_DIR/libkrun.dylib" "$OUT_DIR/libkrun.dylib"
    ;;
  Linux)
    cp -f "$KRUN_DEPS_DIR/libkrun.so" "$OUT_DIR/libkrun.so"
    ;;
  *)
    printf 'unsupported host OS: %s\n' "$(uname -s)" >&2
    exit 1
    ;;
esac

printf 'Packaged krun runtime in %s\n' "$OUT_DIR"
