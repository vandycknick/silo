# Silo arm64 guest-kernel configuration
#
# This file contains only arm64 and Apple virtual-platform policy. Shared
# runtime capabilities live in common.config.

# CPU and scheduling
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_ARM64_VA_BITS_48=y
CONFIG_PARAVIRT=y
CONFIG_RANDOMIZE_BASE=y
# CONFIG_COMPAT is not set
# CONFIG_EFI is not set
# CONFIG_SUSPEND is not set
# CONFIG_NUMA is not set
# CONFIG_MEMORY_HOTPLUG is not set

# Idle CPUs should stop generating unnecessary host wakeups. PSCI is the
# standard arm64 virtual CPU idle interface exposed by VZ-class platforms.
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_ARM_PSCI_CPUIDLE=y

# Nested virtualization
#
# KVM is guest-host functionality here: it exposes /dev/kvm inside the arm64
# VM so the guest can act as an L1 hypervisor.
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y

# Apple virtual-platform device discovery
#
# Virtualization.framework presents devices through a generic ECAM PCI host.
# Keep both PCI and MMIO virtio transports built in so direct-boot variants can
# enumerate their boot devices without modules.
CONFIG_PCI=y
CONFIG_PCI_ECAM=y
CONFIG_PCI_HOST_COMMON=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y

# Wall clock
#
# The host-backed PL031 RTC initializes CLOCK_REALTIME. Guest time must not be
# written back to the virtual RTC.
CONFIG_RTC_CLASS=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_HCTOSYS_DEVICE="rtc0"
# CONFIG_RTC_SYSTOHC is not set
# CONFIG_RTC_NVMEM is not set
CONFIG_RTC_DRV_PL031=y

# Virtual power button used by Virtualization.framework requestStop().
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_PL061=y

# hvc0 is the supported console. Physical UART families are intentionally
# absent from this direct-boot virtual machine kernel.
# CONFIG_SERIAL_8250 is not set
# CONFIG_SERIAL_AMBA_PL011 is not set

# Physical-platform subsystems unavailable in the VM.
# CONFIG_IOMMU_SUPPORT is not set
# CONFIG_ACPI is not set
