# Silo x86_64 guest-kernel configuration
#
# This file contains only x86_64 and libkrun virtual-platform policy. Shared
# runtime capabilities live in common.config.

# CPU and scheduling
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RELOCATABLE=y
# CONFIG_VMAP_STACK is not set
# CONFIG_SUSPEND is not set
# CONFIG_NUMA is not set
# CONFIG_MEMORY_HOTPLUG is not set

# KVM guest optimizations and nested virtualization
#
# KVM_GUEST optimizes this kernel as an L1 guest. KVM_INTEL and KVM_AMD expose
# /dev/kvm so the same image can run nested guests on either host vendor.
CONFIG_KVM_GUEST=y
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y

# libkrun direct-boot devices
#
# Current libkrun guests use command-line virtio-mmio devices and expose no
# ACPI tables or PCI host. Excluding both removes broad physical-PC support.
CONFIG_OF=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
# CONFIG_PCI is not set
# CONFIG_ACPI is not set

# Idle behavior for virtual CPUs.
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y

# hvc0 is the supported console. Probing legacy 8250 ports adds boot latency
# and does not connect to libkrun's virtio console.
# CONFIG_SERIAL_8250 is not set
# CONFIG_PNP is not set
# CONFIG_KEYBOARD_ATKBD is not set
# CONFIG_MOUSE_PS2 is not set
# CONFIG_SERIO_I8042 is not set

# Physical-PC facilities not present in the libkrun machine model.
# CONFIG_IOMMU_SUPPORT is not set
# CONFIG_X86_MCE is not set
# CONFIG_RTC_CLASS is not set
# CONFIG_X86_VERBOSE_BOOTUP is not set
# CONFIG_X86_DEBUG_FPU is not set
