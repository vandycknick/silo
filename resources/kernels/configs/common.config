# Silo shared guest-kernel configuration
#
# This is a Kconfig miniconfig, not a generated .config. It contains only
# product requirements and deliberate policy. Kconfig supplies transitive
# dependencies in the generated build configuration.

# Core userspace and direct boot
#
# Silo boots a static initramfs directly, then switches to an ext4 root disk.
# Modern guest userspace relies on the fd APIs, IPC, file notifications, and
# device nodes below. Modules stay disabled so every boot-critical facility is
# available before userspace can load anything.
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_MEMFD_CREATE=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set
# CONFIG_MODULES is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_MISC=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_STANDALONE=y
CONFIG_PREVENT_FIRMWARE_BUILD=y
CONFIG_TTY=y
CONFIG_UNIX98_PTYS=y
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y
# CONFIG_DEVMEM is not set
# CONFIG_DEVPORT is not set
# CONFIG_COMPAT_BRK is not set

# Scheduling and idle behavior
#
# Tickless operation avoids waking an otherwise idle VM. High-resolution
# timers remain required by runtimes and ordinary Linux userspace.
CONFIG_NO_HZ_FULL=y
CONFIG_NO_HZ=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_SCHED_AUTOGROUP=y
CONFIG_PREEMPT_LAZY=y
# CONFIG_PREEMPT_DYNAMIC is not set

# Container isolation and resource accounting
#
# These are the shared cgroup v2, namespace, seccomp, and BPF facilities used
# by rootful Docker, containerd, runc, and k3s. CPU bandwidth is required for
# cgroup v2 cpu.max; without it runc fails while creating containers.
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_CGROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_PERF_EVENTS=y
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_TRANSPARENT_HUGEPAGE=y

# Base networking
#
# IPv4 DHCP configures the initial virtio-net interface. IPv6, packet sockets,
# and Unix sockets are part of the supported guest and container environment.
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_IPV6=y
# CONFIG_IPV6_SIT is not set
CONFIG_INET_DIAG=y
CONFIG_NETLINK_DIAG=y

# Docker firewall and bridge networking
#
# Supported guest images may invoke iptables-legacy or iptables-nft. Both
# paths are intentional. Missing options here have caused absent nat/raw
# tables, unsupported conntrack matches, and failure to create DOCKER chains.
# NETFILTER_XTABLES_COMPAT is intentionally absent: it only translates for
# 32-bit xtables binaries, while supported Silo guests are 64-bit.
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CT_NETLINK=y
CONFIG_NF_NAT=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XTABLES_LEGACY=y
CONFIG_NETFILTER_XT_NAT=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_IPTABLES_LEGACY=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_RAW=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_TARGET_REDIRECT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_IPTABLES_LEGACY=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP6_NF_RAW=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_TARGET_REJECT=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_CT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_COMPAT=y
CONFIG_BRIDGE=y
CONFIG_VETH=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# Kubernetes, Flannel, network policy, and Istio
#
# Flannel uses VXLAN. kube-proxy and network policy require traffic control,
# xtables expressions, and ipset. Istio requires owner matching and redirect.
# Keeping this section distinct makes the cost of the Kubernetes compatibility
# contract visible even though it currently ships in the default kernel.
CONFIG_VXLAN=y
CONFIG_NET_SCHED=y
CONFIG_NET_CLS=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_CLS_CGROUP=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_NET_CLASSID=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_NETFILTER_XT_TARGET_CT=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_NFACCT=y
CONFIG_NETFILTER_XT_MATCH_OWNER=y
CONFIG_NETFILTER_XT_MATCH_PHYSDEV=y
CONFIG_NETFILTER_XT_MATCH_RECENT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_STATISTIC=y
CONFIG_IP_SET=y
CONFIG_IP_SET_BITMAP_IP=y
CONFIG_IP_SET_BITMAP_IPMAC=y
CONFIG_IP_SET_BITMAP_PORT=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_IPMARK=y
CONFIG_IP_SET_HASH_IPPORT=y
CONFIG_IP_SET_HASH_IPPORTIP=y
CONFIG_IP_SET_HASH_IPPORTNET=y
CONFIG_IP_SET_HASH_IPMAC=y
CONFIG_IP_SET_HASH_MAC=y
CONFIG_IP_SET_HASH_NETPORTNET=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_NETNET=y
CONFIG_IP_SET_HASH_NETPORT=y
CONFIG_IP_SET_HASH_NETIFACE=y
CONFIG_IP_SET_LIST_SET=y

# Shared virtio devices
#
# Both hypervisors expose block, network, console, vsock, RNG, balloon, and
# filesystem devices through virtio. Transport selection remains architecture
# specific. The RNG must initialize the CRNG before the agent creates SSH keys.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HVC_DRIVER=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_VIRTIO_BALLOON=y

# Host filesystem sharing
#
# virtiofs is Silo's only host-directory sharing mechanism. FUSE is a required
# dependency; 9P is intentionally absent.
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# Nested virtualization datapath
#
# Architecture files enable the appropriate KVM implementation. These shared
# facilities make nested vsock and network devices useful to nested guests.
CONFIG_TUN=y
CONFIG_VHOST_MENU=y
CONFIG_VHOST_NET=y
CONFIG_VHOST_VSOCK=y

# Filesystems
#
# ext4 is the default root image format and is resized online by silo-agent.
# Btrfs remains a supported guest filesystem. overlayfs backs Docker overlay2.
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
# CONFIG_RAID6_PQ_BENCHMARK is not set
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_CONFIGFS_FS=y
CONFIG_FS_POSIX_ACL=y
# CONFIG_DNOTIFY is not set
# CONFIG_MISC_FILESYSTEMS is not set

# Security and sandbox compatibility
#
# Landlock is required by pacman/libalpm sandboxing. SELinux and seccomp keep
# supported distribution images functional. Lockdown preserves the existing
# confidentiality policy. Modules and runtime firmware loading are absent.
CONFIG_KEYS=y
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_SAFESETID=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_DEFAULT_SECURITY_DAC=y
CONFIG_LSM="landlock,lockdown,yama,safesetid,selinux,bpf"

# Cryptographic primitives required by filesystems and security userspace
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_XXHASH=y
CONFIG_CRYPTO_BLAKE2B=y

# Diagnostics retained for production support
#
# Embed the resolved config so a running guest can prove what it booted. Keep
# ordinary timestamped printk output, but omit tracing and verbose call-site
# noise from the release kernel.
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
# CONFIG_PRINTK_CALLER is not set
CONFIG_KALLSYMS=y
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_PROFILING is not set
# CONFIG_DEBUG_INFO is not set

# Deliberately unsupported physical-device families
#
# Silo guests receive only the virtual devices documented above. Keeping these
# top-level families disabled prevents Kconfig defaults from pulling broad host
# hardware support back into the kernel.
# CONFIG_NET_9P is not set
# CONFIG_9P_FS is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_HWMON is not set
# CONFIG_STAGING is not set
# CONFIG_ETHERNET is not set
# CONFIG_HID is not set
# CONFIG_THERMAL is not set
# CONFIG_REGULATOR is not set
# CONFIG_WATCHDOG is not set
# CONFIG_KEXEC is not set
# CONFIG_KEXEC_FILE is not set
# CONFIG_HIBERNATION is not set
